  color: #fff;
  font-size: 12px;
  border-radius: 3px;
  margin-top: 5px;

  display: inline-block;
  padding: 6px 10px;
}






.sidebar .widget.subscribe-widget{
  background: linear-gradient(180deg,#19b37f,#2ed573);
  color:white;
  border-radius:14px;
 box-shadow: 0 0 10px rgba(39, 37, 37, 0.18);
  padding:25px;
}


.sidebar .widget.contact-widget{
  background: linear-gradient(180deg,#6c7cff,#6a35d4);
  color:white;
  border-radius:14px;
  box-shadow: 0 0 10px rgba(39, 37, 37, 0.18);
  padding:25px;
}


.sidebar .widget.subscribe-widget h3,
.sidebar .widget.contact-widget h3{
  font-size:20px;
  margin-bottom:18px;
}


.sidebar .widget.subscribe-widget label,
.sidebar .widget.contact-widget label{
