}

.bg-sub{
  background:#ffffff;
  padding:20px;
  border-radius:10px;
  
}

.text-con{
  font-size:18px;
  font-weight:600;
  margin-bottom:15px;
  text-align: center;
}
.text-sub{
  font-size:18px;
  font-weight:600;
  margin-bottom:15px;
  text-align: center;
}

.bg-box{
  background:#f0f4f8;
  padding:15px;
  border-radius:8px;
  margin-top:10px;

  text-align: center;
}

.sponsor-box{
  background:#cfcfcf;
  height:250px;
  border-radius:6px;
  margin-top:10px;

  display:flex;
  align-items:center;
  justify-content:center;

  color:#555;
  font-size:14px;
}
.site-footer{
  background: linear-gradient(90deg,#10151c,#1a1f28);
