* {
  box-sizing: border-box;
  margin: 0;
  padding: 0;
}

body {
  font-family: "Kanit", "Segoe UI", Helvetica, sans-serif;
  background-color: #f5f5f5;
  color: #525151;
}

.wrapper {
  width: 1000px;
  max-width: 100%;
  margin: 0 auto;
  /*background-color: aqua;*/
}

/*=============Header==============*/
.site-header {
  background-color: white;
  padding: 20px 0;
  border-bottom: 2px solid rgb(104, 94, 94);
}

.box-header-inner {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.header-title {
  font-weight: 600;
  font-size: 1.5rem;
  margin-bottom: 4px;
}

.header-subtitle {
  font-weight: 400;
  font-size: 0.8rem;
  color: #777272;
}

.social-icon a {
  font-weight: 600;
  font-size: 1rem;
  color: #524d4d;

  border: 1px solid #313131;
  border-radius: 50%;
  width: 30px;
  height: 30px;

  display: inline-flex;
  justify-content: center;
  align-items: center;

  margin-left: 10px;

  transition: all 0.3s ease;
}

.social-icon a:hover {
  border-color: #090dee;
  background-color: #03286d;
  color: #ffffff;

  transform: translateY(-5px);
}

a {
  text-decoration: none;
  color: #056392;
}

a:hover {
  text-decoration: underline;
}

/*=============Navbar==============*/

.main-nav {
  background-color: #065379;
}

.nav-menu {
  list-style: none;
  display: flex;

  flex-wrap: wrap;
  /*gap: 15px;*/
}

.nav-menu li a {
  color: white;
  font-size: 0.9rem;
  font-weight: 400;

  display: block;
  padding: 10px 15px;
}

.nav-menu li a:hover {
  background-color: #035882;
}

.nav-menu li a.active {
  background-color: #035882;
}

/*=============Hero Section==============*/

.hero-content {
  background-color: #c4bfbf;
  padding: 30px 0;
  box-shadow: 0 4px 15px rgb(145, 145, 145);
  margin-bottom: 30px;
}

.hero-title {
  font-size: 2rem;
  font-weight: 700;
  color: #ffffff;
  text-shadow: 2px 2px 4px #313131;

  text-align: center;
  margin-bottom: 20px;
}

.hero-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(250px, 1fr));
  gap: 15px;
  grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
}

.hero-item {
  background-color: white;
  padding: 25px;
  border-radius: 8px;

  transition: all 0.3s ease;
}

.hero-item:hover {
  transform: translateY(-5px);
  box-shadow: 0 8px 25px rgba(0, 0, 0, 0.15);
  background: white;
}

.hero-item h3 {
  font-size: 1.2rem;
  font-weight: 600;
  color: #333;
  line-height: 1.3;
  margin-bottom: 10px;
}

.hero-item p {
  font-size: 0.9rem;
  color: #666;
  line-height: 1.6;
  margin-bottom: 15px;
}

.hero-item .read-more {
  font-size: 0.9rem;
  font-weight: 500;
  color: #1e8bc3;

  display: inline-block;
}

.hero-item .read-more:hover {
  color: #764ba2;
  text-decoration: none;
}

.hero-item .read-more::after {
  content: "→";
  margin-left: 5px;

  transition: margin-left 0.3s ease;
}

.hero-item .read-more:hover::after {
  margin-left: 10px;
}

/*=============Page Section==============*/
.content-layout {
  display: grid;
  grid-template-columns: 2fr 1fr;
  /*background-color: #035882;*/
  gap: 20px;
}


.card {
  background-color: #ffffff;
  border-radius: 4px;
  padding: 15px;
  box-shadow: 0 2px 8px rgb(182, 181, 181);
}

.card+.card {
  margin-top: 5px;
}

.post-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.date-circle {
  width: 55px;
  height: 55px;
  background-color: #3b50ce;
  border-radius: 50%;

  font-size: 0.65rem;
  color: white;
  font-weight: 600;

  display: flex;
  justify-content: center;
  align-items: center;
  flex-direction: column;
}

.date-day {
  font-size: 1.2rem;
  font-weight: 600;
  line-height: 1;
}

.post-title {
  font-size: 1.1rem;
  font-weight: 600;
}

.card-header-line {
  font-size: 0.7rem;
  font-weight: 500;
  text-transform: uppercase;
  color: #777;
}

.post-footer {
  color: #555;
  font-size: 0.65rem;

  border-top: 1px solid #ddd;
  padding-top: 8px;
}

.post-img {
  height: 200px;
  overflow: hidden;


  margin: 15px 0;
}

.post-img img {

  width: 100%;
  height: auto;
  object-fit: cover;
}

.post-detail {
  color: #555;
  font-size: 0.8rem;
  line-height: 1.6;
}



.table-description {
  font-size: 0.84;
  color: #666;
  line-height: 1.5;
  margin-bottom: 15px;
}

.comparison-table {
  width: 100%;
  border-radius: 8px;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
  margin: 20px 0;
  overflow: hidden;
}

.comparison-table th {
  background: linear-gradient(45deg, #667eea 0%, #764ba2 100%);
  color: white;
  font-size: 1rem;
  font-weight: 600;

  text-align: left;
  padding: 15px;
}

.comparison-table td {
  border-bottom: 1px solid #e0e0e0;
  background-color: #ffffff;
  padding: 12px 15px;
}

.comparison-table tr:nth-child(even) td {
  background-color: #f8f9fa;
}

.comparison-table tr:hover td {
  background-color: #e3f2fd;
  transition: background-color 0.3s ease;
}

.comparison-table .feature {
  font-weight: 600;
  color: #333;
  background-color: #f0f4f8;
}

.comparison-table .pro {
  color: #28a745;
  font-weight: 500;
}

.comparison-table .con {
  color: #dc3545;
  font-weight: 500;
}

.comparison-table .neutral {
  color: #6c757d;
}


.contact-title {
  font-size: 28px;
  font-weight: 600;
  text-align: center;
  color: #333;
  margin-bottom: 15px;
  text-shadow: 0 2px 4px rgba(0, 0, 0, 0.08);
}

.contact-form-main {

  width: 95%;
  border: 1px solid #e0e0e0;
  border-radius: 15px;
  background: #fff;
  padding: 40px;
  margin: 0 auto;
  box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);

}


.form-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20px;
  margin-bottom: 20px;
}

.form-row.full-width {
  grid-template-columns: 1fr;
}

.form-group {
  margin-bottom: 15px;
}


.form-label {
  display: block;
  font-size: 14px;
  font-weight: 600;
  margin-bottom: 8px;
}


.form-input,
.form-select,
.form-textarea {
  width: 100%;
  padding: 12px 15px;
  border-radius: 8px;
  font-size: 14px;
  transition: all 0.2s ease;
}

.form-textarea {
  min-height: 100px;
  resize: vertical;
}

.form-select {
  cursor: pointer;
}


.contact-form-main .form-input,
.contact-form-main .form-select,
.contact-form-main .form-textarea {
  background: #f8f9fa;
  border: 2px solid #e9ecef;
  color: #333;
}


.contact-form-main .form-input:focus,
.contact-form-main .form-select:focus,
.contact-form-main .form-textarea:focus {
  outline: none;
  background: #fff;
  border-color: #667eea;
  box-shadow: 0 0 0 3px rgba(102, 126, 234, 0.18);
  transform: translateY(-1px);
}


.form-checkbox-group {
  display: flex;
  flex-wrap: wrap;
  gap: 15px;
  margin-top: 10px;
}

.checkbox-item {
  display: flex;
  align-items: center;
  font-size: 14px;
}


.contact-form-main .checkbox-item {
  color: #333;
}

.checkbox-item input[type="checkbox"] {
  margin-right: 8px;
  transform: scale(1.15);
  accent-color: #ff6b6b;
}


.form-button {
  width: 100%;
  border: none;
  padding: 12px 30px;
  border-radius: 25px;
  font-size: 16px;
  font-weight: 600;
  cursor: pointer;
  color: #fff;
  transition: all 0.2s ease;
}


.contact-form-main .form-button {
  background: linear-gradient(45deg, #667eea, #764ba2);
}

.contact-form-main .form-button:hover {
  background: linear-gradient(45deg, #5a67d8, #6b46c1);
  transform: translateY(-2px);
  box-shadow: 0 8px 20px rgba(102, 126, 234, 0.35);
}




.sidebar {
  display: flex;
  flex-direction: column;
  gap: 15px;
}

.sidebar .widget {
  background: #fff;
  border-radius: 3px;
