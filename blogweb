  padding:12px 14px;
  margin-bottom:14px;
  border:none;
  border-radius:10px;
  background:#e9edf0;
  font-size:14px;
  outline:none;
}


.sidebar .widget.contact-widget textarea{
  height:95px;
  resize:none;
}


.sidebar .widget input:focus,
.sidebar .widget select:focus,
.sidebar .widget textarea:focus{
  box-shadow:0 0 0 3px rgba(255,255,255,.35);
}


.btn-gradient{
  width:100%;
  padding:13px;
  border:none;
  border-radius:30px;
  background: linear-gradient(45deg,#ff7e7e,#ffb199);
  color:white;
  font-weight:600;
  font-size:15px;
